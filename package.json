{
  "name": "comboweather",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-platform weather app combining SMHI, MET Norway, and DMI forecasts.",
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r --parallel --aggregate-output test",
    "typecheck": "pnpm -r --parallel typecheck",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "eslint": "^9.18.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.19.0"
  }
}
